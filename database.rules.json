{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        "email":      { ".read": "auth != null" },
        "publicKey":  { ".read": "auth != null" },
        "xp":         { ".read": "auth != null" }
      }
    },

    "userFlags": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (root.child('users/'+auth.uid+'/email').val() === 'ryu694602@gmail.com' || root.child('users/'+auth.uid+'/email').val() === 'zeoxaeon@gmail.com')"
      }
    },

    "follows": {
      ".read": "auth != null",
      "$a": {
        "$b": {
          ".write": "auth != null && auth.uid === $a"
        }
      }
    },

    "followers": {
      ".read": "auth != null",
      "$uid": {
        "$other": {
          ".write": "auth != null && auth.uid === $other"
        }
      }
    },

    "history": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "customAnimes": {
      ".read": true,
      ".write": "auth != null && (root.child('users/'+auth.uid+'/email').val() === 'ryu694602@gmail.com' || root.child('users/'+auth.uid+'/email').val() === 'zeoxaeon@gmail.com')"
    },

    "globalChat": {
      ".read": true,
      ".write": "auth != null && !root.child('userFlags/'+auth.uid+'/banned').val()",
      "$msgId": {
        ".validate": "newData.hasChildren(['text','uid','ts'])",
        "uid": { ".validate": "newData.val() === auth.uid" },
        "text": { ".validate": "newData.isString() && newData.val().length <= 1000" }
      }
    },

    "comments": {
      "$scope": {
        ".read": true,
        ".write": "auth != null && !root.child('userFlags/'+auth.uid+'/banned').val()",
        "$commentId": {
          "likes": {
            "$uid": {
              ".write": "auth != null && auth.uid === $uid"
            }
          },
          "replies": {
            ".write": "auth != null && !root.child('userFlags/'+auth.uid+'/banned').val()"
          }
        }
      }
    },

    "chats": {
      "$chatId": {
        ".read":  "auth != null && $chatId.contains(auth.uid)",
        ".write": "auth != null && $chatId.contains(auth.uid) && !root.child('userFlags/'+auth.uid+'/banned').val()"
      }
    }
  }
}
